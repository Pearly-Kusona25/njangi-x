# Expo public environment variables
EXPO_PUBLIC_SUPABASE_URL=https://.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_FAPSHI_API_USER=your-fapshi-api-user
EXPO_PUBLIC_FAPSHI_API_KEY=your-fapshi-api-key

# Backend / Supabase service role
SUPABASE_URL=https://.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FUNCTIONS_URL=

# Fapshi webhook and server-side config
FAPSHI_BASE_URL=https://api.fapshi.com/v1
FAPSHI_WEBHOOK_SECRET=your-fapshi-webhook-secret
FAPSHI_WEBHOOK_URL=https://your-app.com/functions/fapshi-webhook

# Optional local DB connection for migrations
SUPABASE_DB_URL=
